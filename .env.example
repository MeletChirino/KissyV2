# Bot token from @BotFather. Required.
BOT_TOKEN=replace-me

# Public base URL Telegram will POST updates to. No trailing slash.
# Must be HTTPS in production. Telegram delivers only to ports 443, 80, 88, 8443
# unless ip_address is set when the webhook is registered.
WEBHOOK_URL=https://your-domain.example.com

# Interface to bind to. Default: 0.0.0.0
WEBHOOK_LISTEN=0.0.0.0

# Port to listen on. Default: 8443
WEBHOOK_PORT=8443

# Optional but recommended. Telegram will send this in the
# X-Telegram-Bot-Api-Secret-Token header. Must be 1-256 chars from A-Z a-z 0-9 _ -.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET_TOKEN=

# Ollama server address (no scheme, no trailing slash).
# Example local default: 127.0.0.1:11434
OLLAMA_HOST=127.0.0.1:11434

# Ollama model name to use for chat completions.
# Must be pulled on the server first:  ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# --- InvoiceNinja (docker-compose.yaml) ---------------------------
# Defaults from the official invoiceninja/dockerfiles Debian image.
# Generate APP_KEY with:
#   docker run --rm invoiceninja/invoiceninja-debian php artisan key:generate --show

# Public URL the app will be reached at. No trailing slash.
#
# Local dev (this machine only):         http://localhost/
# VPS running docker compose directly:    http://<vps-public-hostname-or-ip>/
# VPS behind a TLS-terminating proxy:     https://in.example.com/
#
# This must match how users actually reach nginx. Wrong values break
# email links, OAuth redirects, and absolute URLs in generated PDFs.
APP_URL=http://localhost/

# 32-char base64 Laravel key. Required on first boot.
APP_KEY=

# Laravel environment. Default: production.
APP_ENV=production

# true = verbose errors, false = production-style. Default: false.
# Must be false on a VPS — APP_DEBUG=true exposes stack traces and
# .env contents on every error page.
APP_DEBUG=false

# Set true once you put a real TLS-terminating proxy in front of nginx.
#
# Local dev over plain http://localhost/:  false
# VPS exposed to the internet at all:      true  (even without a proxy,
#                                          set this and front it with
#                                          nginx/Caddy/Traefik doing TLS)
#
# When true, InvoiceNinja forces HTTPS-only generated links and refuses
# insecure cookies. Leaving it false on a public VPS leaks session cookies.
REQUIRE_HTTPS=false

# Initial admin account. Required for first boot (the container's init.sh
# exits 1 if these are empty). Remove or change them after first login —
# the account can be re-created from the UI.
IN_USER_EMAIL=admin@example.com
IN_PASSWORD=changeme!

# Static API token from the InvoiceNinja UI: log in as the user that
# will own the API calls, then go to "User → API Tokens" and copy the
# token. Used by src/invoiceninja/InvoiceNinjaClient for all REST calls.
#
# Generate one with:
#   curl -X POST "$INVOICENINJA_BASE_URL/api/v1/login" \
#        -H "Content-Type: application/json" \
#        -d '{"email":"'$IN_USER_EMAIL'","password":"'$IN_PASSWORD'"}'
# The response's data[0].token (or your pre-generated one) goes here.
#
# If this is empty, the client will try to log in with IN_USER_EMAIL /
# IN_PASSWORD on every cold start and use the returned token for the
# session lifetime. Static token is strongly preferred.
INVOICE_NINJA_TOKEN=

# Base URL the InvoiceNinja REST API is reachable at. No trailing slash
# (the client appends /api/v1/* itself).
#
# Bot running on the docker host:               http://localhost/
# Bot running in a container on the same network: http://nginx/
INVOICENINJA_BASE_URL=http://localhost/

# MySQL credentials used by both the app and the mysql container.
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ninja
DB_USERNAME=ninja
DB_PASSWORD=replace-me
DB_ROOT_PASSWORD=replace-me-too

# Mirror for the mysql container's healthcheck (mysqladmin ping).
# Must match DB_USERNAME / DB_PASSWORD above.
MYSQL_USER=ninja
MYSQL_PASSWORD=replace-me

# --- Kissy v2 (telegram_bot) ---------------------------------------
# See docs/02_use_cases.md for what each variable is used for.

# --- Inference Provider --------------------------------------------
# Selects the inference backend used by KissyEngine. Allowed values:
#   ollama  - default; local Ollama server reachable at OLLAMA_HOST.
#   openai  - hosted OpenAI API (future).
#   google  - hosted Google API (future).
# When switching to openai/google, also set INFERENCE_API_KEY below and
# OLLAMA_HOST/OLLAMA_MODEL become unused.
INFERENCE_PROVIDER=ollama

# API key for hosted inference providers (openai/google). Leave empty
# when INFERENCE_PROVIDER=ollama. Never commit a real key.
INFERENCE_API_KEY=

# --- Telegram allowlist --------------------------------------------
# Single phone number (E.164, e.g. +15551234567) that the OWNER bot will
# respond to. Any other chat is rejected. Leave empty to fail closed
# (recommended in production until the OWNER number is known).
OWNER_PHONE_ALLOWLIST=

# Display name the bot uses to address the OWNER in greetings,
# summaries, and notifications. First name preferred (e.g. "Meli").
# Falls back to a neutral greeting if unset.
USER_NAME=

# Single phone number for the SYSADMIN bot. Leave empty to disable
# admin commands entirely. The SYSADMIN bot is a separate Telegram bot
# (separate BOT_TOKEN_ADMIN below) on a separate phone.
SYSADMIN_PHONE_ALLOWLIST=

# --- Streamlit authentication --------------------------------------
# production: Google OAuth only, accepting only OWNER_GOOGLE_EMAIL.
# development: DEV_DASHBOARD_PASSWORD is accepted as a bypass.
APP_ENV=production

# Email of the Google account allowed to log into Streamlit. Set by
# UC-ADM-05 (sysadmin command /set-owner-email). Must match the email
# returned by the Google OAuth callback.
OWNER_GOOGLE_EMAIL=

# Shared password used ONLY when APP_ENV=development. Required for
# UC-S-A03 (dev login). Ignored when APP_ENV=production. Fail-fast if
# unset in dev. Never commit a real password.
DEV_DASHBOARD_PASSWORD=

# --- Admin bot (separate Telegram instance) ------------------------
# Token for the SYSADMIN bot. Used for /bind, /allowlist,
# /set-owner-email, and abuse alerts. Optional but recommended.
# Generate with @BotFather on a separate account from the OWNER bot.
BOT_TOKEN_ADMIN=

# Public base URL Telegram will POST admin updates to. No trailing slash.
# Same HTTPS/port rules as WEBHOOK_URL.
WEBHOOK_URL_ADMIN=

# --- SYSADMIN first-bind code --------------------------------------
# One-time code that SYSADMIN must present to /bind the admin bot
# (UC-ADM-06). Generated by the sysadmin via SSH; consumed on first
# successful bind. Leave empty to disable /bind entirely (the
# SYSADMIN_PHONE_ALLOWLIST must then be set out of band).
ADMIN_BIND_CODE=

# --- Dialog & notification tuning ----------------------------------
# Max messages per open dialog before UC-T-L01 fires.
CONVERSATION_MSG_CAP=50

# Minutes of inactivity before an open dialog is auto-closed
# (UC-T-L02 / UC-DL-01).
CONVERSATION_IDLE_MINUTES=30

# Days to retain closed dialogs in SQLite before UC-DL-02 purges them.
# audit_log is kept separately and is NOT affected.
CONVERSATION_RETENTION_DAYS=30

# Max messages per chat per minute before UC-ADM-01 fires (429 + alert).
RATE_LIMIT_PER_MINUTE=100

# Max new dialogs per OWNER chat per day before UC-ADM-02 alerts SYSADMIN.
DAILY_DIALOG_ABUSE_THRESHOLD=20

# Local time to deliver UC-N-01 (Monday weekly + daily summary).
SUMMARY_HOUR=8
SUMMARY_MINUTE=30

# Max times UC-T-L04 may reschedule the summary before dropping/queueing.
SUMMARY_RESCHEDULE_MAX=3

# TTL of the Google-account claim token issued by UC-S-A01.
CLAIM_TOKEN_TTL_MINUTES=60
